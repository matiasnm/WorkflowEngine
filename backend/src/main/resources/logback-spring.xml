<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- Plain text for local development profiles -->
  <springProfile name="memory | dev-h2 | dev-pg">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{HH:mm:ss.SSS} %-5level [%logger{36}] %msg%n</pattern>
      </encoder>
    </appender>
  </springProfile>

  <!-- Structured JSON for jpa / pg when NOT in dev mode (CI, staging, production) -->
  <springProfile name="(h2 | pg) &amp; !dev">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LogstashEncoder"/>
    </appender>
  </springProfile>

  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
  </root>

</configuration>
